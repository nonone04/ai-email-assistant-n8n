        "categories": {
          "categories": [
            {
              "category": "New Lead Classifier",
              "description": "Identifies emails from potential customers interested in the company's services. These emails usually contain inquiries about website design, web development, SEO, branding, pricing, or requests for a consultation."
            },
            {
              "category": "Existing Client Classifier",
              "description": "Identifies emails sent by existing clients regarding ongoing projects, project updates, design revisions, feature requests, meetings, feedback, or any communication related to active services."
            },
            {
              "category": "Technical Support Classifier",
              "description": "Identifies emails reporting technical problems such as website downtime, bugs, hosting issues, login problems, domain or email issues, SSL errors, performance problems, or requests for technical assistance."
            },
            {
              "category": "Sales / Quote Classifier",
              "description": "Identifies emails requesting pricing information, quotations, project estimates, proposals, service packages, invoices, or any sales-related inquiry before starting a project."
            },
            {
              "category": "Partnership Classifier",
              "description": "Identifies emails related to business partnerships, collaboration opportunities, freelancer applications, agency cooperation, affiliate programs, sponsorships, or networking proposals."
            },
            {
              "category": "Newsletter / Marketing Classifier",
              "description": "Identifies promotional emails, newsletters, product announcements, marketing campaigns, advertisements, discounts, webinars, events, software updates, and other non-personal marketing communications."
            },
            {
              "category": "Spam / Other Classifier",
              "description": "Identifies spam, phishing attempts, irrelevant emails, unsolicited messages, suspicious content, or any email that does not belong to the other defined categories."
            }
          ]
        },
        "options": {}
      },
