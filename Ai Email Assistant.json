    {
      "parameters": {
        "jsCode": "let text = $json.output[0].content[0].text;\n\ntext = text.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\nconst ai = JSON.parse(text);\n\nreturn [\n  {\n    json: {\n      ...$json,\n      priority: ai.priority,\n      summary: ai.summary,\n      lead_score: ai.lead_score,\n      deal_value: ai.deal_value,\n      closing_probability: ai.closing_probability,\n      sentiment: ai.sentiment,\n      recommended_action: ai.recommended_action,\n      status: ai.status,\n      reply: ai.reply\n      \n    }\n  }\n];"
      },
